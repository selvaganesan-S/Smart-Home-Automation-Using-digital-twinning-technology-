int fire,vib,oc,vibf;

void print3(int v) {
  if (v < 0) {
    Serial.print("-");
    v = abs(v);
  }
  if (v < 100) Serial.print("0");
  if (v < 10)  Serial.print("0");
  Serial.print(v);
}

int v1,v2,v3;
int sc;


void loop()
{
  temp=(analogRead(32)/4/17);
  
  v1=((analogRead(33)/14));
  v2=((analogRead(34)/14));
  v3=((analogRead(35)/14));
  sc=((analogRead(15)/14));
  
  curr=40+rand()%10;

  lcd.setCursor(0, 0);
  lcd.print("V:");
  lcd.print((float)v1/10);
  lcd.print(" ");
  lcd.print((float)v2/10);
