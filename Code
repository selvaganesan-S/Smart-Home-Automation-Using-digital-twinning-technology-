  lcd.print(curr);
  lcd.print(" ");
  lcd.print("Tm:");
  lcd.print(temp);
  lcd.print(" ");
  lcd.print(sc);
  lcd.print(" ");

  if(temp>40)
  {
    digitalWrite(23,1);
  }
  else
  {
    digitalWrite(23,0);
  }

  Serial.print("A");
  print3(temp*10);
  Serial.print("B");
  print3(v1);
  Serial.print("C");
  print3(v2);
  Serial.print("D");
  print3(v3);
  Serial.print("E");
  print3(curr);
  Serial.println("F");


  if(sc>10)
  {
    digitalWrite(25,1);
    digitalWrite(26,0);
    digitalWrite(27,1);
    digitalWrite(14,0);
    delay(200);
    digitalWrite(25,0);
    digitalWrite(26,1);
    digitalWrite(27,0);
    digitalWrite(14,1);
    delay(200);         
  }


 while (Serial.available()) {
    // get the new byte:
    char inChar = (char)Serial.read();
    // add it to the inputString:
  
    if (inChar == 'X') {
      digitalWrite(21,1);
    }
    if (inChar == 'x') {
      digitalWrite(21,0);
    }
    if (inChar == 'Y') {
      digitalWrite(22,1);
    }
    if (inChar == 'y') {
      digitalWrite(22,0);
    }
    if (inChar == 'Z') {
      digitalWrite(17,1);
    }
    if (inChar == 'z') {
      digitalWrite(17,0);
    }
    
  }
  
  delay(200);
}
